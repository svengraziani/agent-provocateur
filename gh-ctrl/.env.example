# GitHub OAuth App credentials
# Create one at: https://github.com/settings/developers -> OAuth Apps -> New OAuth App
# Homepage URL: http://localhost:3001
# Authorization callback URL: http://localhost:3001/api/auth/callback

GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Optional: override the OAuth callback URL for production deployments
# GITHUB_REDIRECT_URI=https://yourdomain.com/api/auth/callback
