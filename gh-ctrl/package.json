{
  "name": "gh-ctrl",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch src/index.ts",
    "dev:client": "cd client && bun run dev",
    "build": "cd client && bun run build",
    "start": "bun src/index.ts",
    "test:unit": "bun test"
  },
  "dependencies": {
    "concurrently": "^8.2.0",
    "drizzle-orm": "^0.31.0",
    "hono": "^4.4.0",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "drizzle-kit": "^0.22.0",
    "@types/bun": "latest"
  }
}
