{
  "manifest_version": 3,
  "name": "Vibe and Conquer",
  "short_name": "V&C",
  "version": "1.0.0",
  "description": "Self-hosted GitHub Command Center Dashboard",
  "permissions": ["sidePanel"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Vibe and Conquer öffnen",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
